PORT=3000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/renex

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=
